generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum TicketStatus {
  OPEN        // Mới tạo, chưa giải quyết
  IN_PROGRESS // Đang xử lý
  SOLVED      // Đã giải quyết
  CLOSED      // Đã đóng
  PENDING     // Đang chờ
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketType {
  INCIDENT
  QUESTION
  TASK
  OTHER
}

model User {
  id              Int       @id @default(autoincrement())
  name            String
  email           String    @unique
  password        String
  role            Role      @default(MEMBER)
  avatar          String?   

  customersCreated Customer[] @relation("UserCustomersCreated") 

  ticketsCreated   Ticket[]  @relation("TicketCreator")
  ticketsAssigned  Ticket[]  @relation("TicketAssignee")

  conversations    Conversation[] @relation("ConversationCreator")
  
  createdTasks     Task[]    @relation("TaskCreator")
  assignedTasks    Task[]    @relation("TaskAssignee")
  
  notes            Note[]    @relation("NoteCreator")
  activityLogs     ActivityLog[] @relation("ActivityLogCreator")

  followedTickets  Ticket[]  @relation("TicketFollowers")

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Customer {
  id          Int      @id @default(autoincrement())
  name        String
  avatar      String?  
  email       String
  phone       String?
  address     String?
  tickets     Ticket[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById Int
  createdBy   User @relation("UserCustomersCreated", fields: [createdById], references: [id])
}

model Ticket {
  id            Int            @id @default(autoincrement())
  title         String
  description   String?
  status        TicketStatus    @default(OPEN)
  priority      TicketPriority  @default(MEDIUM)
  type          TicketType      @default(INCIDENT)
  tags          String[]        @default([])

  createdById   Int
  createdBy     User            @relation("TicketCreator", fields: [createdById], references: [id])

  assignedToId  Int?
  assignedTo    User?           @relation("TicketAssignee", fields: [assignedToId], references: [id])

  customerId    Int
  customer      Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  followers     User[]          @relation("TicketFollowers")

  conversations Conversation[]
  tasks         Task[]        
  notes         Note[]        
  activityLogs  ActivityLog[] 

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Conversation {
  id          Int      @id @default(autoincrement())
  content     String
  channel     String
  type        String   @default("MESSAGE")
  attachments String[] @default([])
  senderName  String?

  ticketId    Int
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdById Int
  createdBy   User     @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model Task {
  id           Int      @id @default(autoincrement())
  content      String
  status       String   @default("PENDING")
  dueDate      DateTime?

  ticketId     Int
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  assignedToId Int?
  assignedTo   User?    @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: Cascade)

  createdById  Int
  createdBy    User     @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  action      String

  ticketId    Int
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdById Int
  createdBy   User     @relation("ActivityLogCreator", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model Note {
  id          Int      @id @default(autoincrement())
  content     String

  ticketId    Int
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdById Int
  createdBy   User     @relation("NoteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}